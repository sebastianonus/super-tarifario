{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/",
      "destination": "/tarifarios/item.html"
    },
    {
      "source": "/item",
      "destination": "/tarifarios/item.html"
    },
    {
      "source": "/modulo",
      "destination": "/tarifarios/modulo.html"
    }
  ]
}
